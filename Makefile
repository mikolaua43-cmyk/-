# Компилятор
CC = gcc

# Флаги компиляции
CFLAGS = -Wall -Wextra -Werror -std=c11 -D_POSIX_C_SOURCE=200809L -D_DEFAULT_SOURCE

# Флаги оптимизации (для отладки или релиза)
# DEBUG: CFLAGS += -g -O0
# RELEASE: CFLAGS += -O2
CFLAGS += -g -O0

# Имя исполняемого файла
TARGET = dirwalk

# Исходные файлы
SRCS = dirwalk.c

# Объектные файлы
OBJS = $(SRCS:.c=.o)

# ============================================
# Основные цели
# ============================================

# Цель по умолчанию
all: $(TARGET)

# Сборка исполняемого файла
$(TARGET): $(OBJS)
	$(CC) $(CFLAGS) -o $(TARGET) $(OBJS)

# Компиляция исходных файлов в объектные
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# ============================================
# Дополнительные цели
# ============================================

# Очистка собранных файлов
clean:
	rm -f $(OBJS) $(TARGET)

# Пересборка
rebuild: clean all

# Запуск программы (тест)
run: $(TARGET)
	./$(TARGET) -l -d -f -s ./

# Установка в систему (требует прав root)
install: $(TARGET)
	install -m 755 $(TARGET) /usr/local/bin/

# Удаление из системы
uninstall:
	rm -f /usr/local/bin/$(TARGET)

# Проверка кода статическим анализатором
check: $(SRCS)
	cppcheck --enable=all $(SRCS)

# ============================================
# Справочная информация
# ============================================

help:
	@echo "Доступные цели:"
	@echo "  all       - Сборка программы (по умолчанию)"
	@echo "  clean     - Удалить скомпилированные файлы"
	@echo "  rebuild   - Очистить и собрать заново"
	@echo "  run       - Собрать и запустить тест"
	@echo "  install   - Установить в /usr/local/bin"
	@echo "  uninstall - Удалить из /usr/local/bin"
	@echo "  check     - Статический анализ кода"
	@echo "  help      - Показать эту справку"

# ============================================
# Зависимости для автоматической пересборки
# ============================================

# Автоматическое создание зависимостей
-include $(SRCS:.c=.d)

%.d: %.c
	@set -e; rm -f $@; \
	$(CC) -MM $(CPPFLAGS) $< > $@.$$$$; \
	sed 's,\($*\)\.o[ :]*,\1.o $@ : ,g' < $@.$$$$ > $@; \
	rm -f $@.$$$$

.PHONY: all clean rebuild run install uninstall check help
